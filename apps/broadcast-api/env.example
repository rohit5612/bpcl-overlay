NODE_ENV=development
PORT=8080
BROADCAST_SECRET=change_me_broadcast_secret_minimum_eight_chars
# Comma-separated — include every Netlify admin + overlay URL (and custom domains)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-admin.netlify.app,https://your-overlay.netlify.app
STATE_BACKEND=memory
REDIS_STATE_KEY=bpc:broadcast:v1
REDIS_UNAVAILABLE_FALLBACK_MEMORY=false
OPENDOTA_RATE_PER_MINUTE=45
STATE_HEARTBEAT_MS=8000
# Required — all player/tournament hero stats are scoped to this league
LEAGUE_ID=19721
# Re-fetch from Steam on API boot only if CSV is missing (rate-limit friendly: use false)
LEAGUE_AUTO_AGGREGATE=false
# Folder for league_{id}_heroes.csv + league_{id}_player_heroes.csv (relative to API cwd)
# Default: apps/broadcast-api/data/league-stats — must exist on the server (git or fetch)
# LEAGUE_STATS_DIR=data/league-stats
# Required — amateur/private leagues are listed via Steam GetMatchHistory (not OpenDota)
STEAM_WEB_API_KEY=
# Optional: comma-separated match IDs merged with Steam history
# LEAGUE_MATCH_IDS=8827988954,8827948881
