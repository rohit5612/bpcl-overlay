{
  "name": "bpc-broadcast-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:overlay": "npm run build --workspace=@bpc/shared-types && npm run build --workspace=overlay-web",
    "build:admin": "npm run build --workspace=@bpc/shared-types && npm run build --workspace=admin-web",
    "build:deploy": "npm run build --workspace=@bpc/shared-types --workspace=@bpc/state-manager --workspace=broadcast-api --workspace=admin-web --workspace=overlay-web",
    "dev:bpc-api": "npm run dev --workspace=broadcast-api",
    "dev:overlay": "npm run dev --workspace=overlay-web",
    "dev:admin": "npm run dev --workspace=admin-web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "heroes:copy-webms": "node scripts/copy-hero-webms.mjs",
    "heroes:download-cdn-webms": "node scripts/download-hero-cdn-webms.mjs",
    "heroes:download-cdn-portraits": "node scripts/download-hero-cdn-portraits.mjs",
    "heroes:generate-index": "npm run build --workspace=@bpc/shared-types && node scripts/generate-hero-index.mjs",
    "roster:enrich-avatars": "npm run build --workspace=broadcast-api && node scripts/enrich-roster-avatars.mjs",
    "heroes:reencode-webms": "node scripts/reencode-hero-webms.mjs",
    "heroes:verify-webms": "node scripts/verify-hero-webms.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0"
  },
  "engines": {
    "node": ">=18"
  }
}
